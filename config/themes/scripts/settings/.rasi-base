* {
    font: "FiraCode Nerd Font 10";
}
window {
    width: 420;
    border-radius: 16px;
    background-color: #1e1e2e;
}
mainbox {
    children: [listview];
    spacing: 4px;
    padding: 8px;
}
listview {
    spacing: 4px;
    dynamic: true;
}
element {
    border-radius: 10px;
    padding: 10px 14px;
    background-color: #313244;
    text-color: #cdd6f4;
}
element selected {
    background-color: #89b4fa;
    text-color: #1e1e2e;
}
element-icon {
    size: 1.2em;
}
element-text {
    horizontal-align: 0.5;
}
