[global]
    # Fuente ligeramente más grande y clara
    font = JetBrainsMono Nerd Font Mono 15

    # Esquinas extra redondeadas (coincide con Rofi)
    corner_radius = 20
    icon_corner_radius = 12

    frame_width = 2
    frame_color = "#faa968"

    # Espaciado entre notificaciones
    gap_size = 8
    separator_height = 2
    separator_color = frame

    padding = 18
    horizontal_padding = 22
    line_height = 5

    # Posición (Top Right con buen margen)
    offset = 25x25
    origin = top-right

    markup = full
    format = "<b>%s</b>\n%b"

    icon_position = left
    icon_theme = Adwaita, hicolor
    icon_path = /usr/share/icons/Adwaita/16x16/status/:/usr/share/icons/Adwaita/16x16/devices/:/usr/share/icons/Adwaita/16x16/apps/:/usr/share/icons/Adwaita/16x16/mimetypes/:/usr/share/icons/Adwaita/32x32/status/:/usr/share/icons/Adwaita/32x32/devices/:/usr/share/icons/Adwaita/48x48/status/:/usr/share/icons/Adwaita/48x48/devices/:/usr/share/icons/Adwaita/scalable/status/:/usr/share/icons/Adwaita/symbolic/status/
    enable_recursive_icon_lookup = true
    max_icon_size = 48
    min_icon_size = 32

    word_wrap = yes
    ellipsize = middle
    ignore_newline = false

    notification_limit = 10
    history_length = 50

    sticky_history = yes
    show_age_threshold = 60

    # Barras de progreso premium
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 180
    progress_bar_max_width = 320
    progress_bar_corner_radius = 5

    highlight = "#faa968"
    background = "#05182eee"
    foreground = "#f6dcac"

    transparency = 10
    sort = yes
    indicate_hidden = yes
    fullscreen = pushback

    mouse_left_click = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_all

    # Evita que se amontonen si son idénticas
    stack_duplicates = true
    hide_duplicate_count = false

    idle_threshold = 120

    close = ctrl+space
    close_all = ctrl+shift+space
    history = ctrl+period
    context = ctrl+shift+period

[urgency_low]
    background = "#05182e"
    foreground = "#303442"
    frame_color = "#303442"
    highlight = "#303442"
    timeout = 4

[urgency_normal]
    background = "#05182e"
    foreground = "#f6dcac"
    frame_color = "#faa968"
    highlight = "#faa968"
    timeout = 6

[urgency_critical]
    background = "#f85525"
    foreground = "#f6dcac"
    frame_color = "#e97b3c"
    highlight = "#e97b3c"
    timeout = 0
    icon = dialog-warning-symbolic
    script = paplay /usr/share/sounds/freedesktop/stereo/alarm-clock-elapsed.oga

# --- REGLAS PERSONALIZADAS ---

# Regla para notificaciones del sistema de oxido-i3-themes
[oxido_system]
    appname = "oxido_system"
    timeout = 3
    # Permitir iconos aunque sean notis de sistema
    # max_icon_size (global-only, ignorado aquí)

# Navegadores
[firefox]
    appname = "Firefox"
    urgency = critical
    timeout = 10

[chromium]
    appname = "Chromium"
    urgency = critical
    timeout = 10

[brave]
    appname = "Brave"
    urgency = critical
    timeout = 10

[chrome]
    appname = "Google-chrome"
    urgency = critical
    timeout = 10

# Utilidades
[screenshot]
    appname = "Screenshot"
    timeout = 5
    urgency = low

[flameshot]
    appname = "flameshot"
    timeout = 5
    urgency = low

# Chat
[telegram]
    appname = "Telegram"
    urgency = critical
    timeout = 8

[telegram-desktop]
    appname = "TelegramDesktop"
    urgency = critical
    timeout = 8

[discord]
    appname = "Discord"
    urgency = critical
    timeout = 8
